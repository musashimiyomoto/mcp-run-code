MCP_API_KEY=change-me
MCP_PORT=8000

# Validation limits
MCP_MAX_CODE_BYTES=32768
MCP_MAX_OUTPUT_BYTES=65536

# Sandbox limits
MCP_TIMEOUT_SECONDS=5
MCP_MEMORY_MB=256
MCP_CPU_COUNT=1
MCP_PIDS_LIMIT=64
MCP_DOCKER_IMAGE=python:3.12-alpine

# Sandbox scheduling / backpressure
MCP_MAX_CONCURRENT_JOBS=4
MCP_QUEUE_WAIT_SECONDS=1

# Optional Linux hardening profiles
# MCP_DOCKER_SECCOMP_PROFILE=/absolute/path/to/seccomp.json
# MCP_DOCKER_APPARMOR_PROFILE=your-apparmor-profile
